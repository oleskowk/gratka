<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>{% block title %}Symfony App{% endblock %}</title>
    <style>
        * {
            margin: 0;
            padding: 0;
            box-sizing: border-box;
        }
        
        body {
            font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, Oxygen, Ubuntu, Cantarell, sans-serif;
            background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
            min-height: 100vh;
            padding: 20px;
        }
        
        .container {
            max-width: 1200px;
            margin: 0 auto;
        }
        
        header {
            text-align: center;
            color: white;
            margin-bottom: 40px;
        }
        
        header h1 {
            font-size: 3em;
            margin-bottom: 10px;
            text-shadow: 2px 2px 4px rgba(0,0,0,0.3);
        }
        
        header p {
            font-size: 1.2em;
            opacity: 0.9;
        }
        
        .navbar {
            display: flex;
            justify-content: space-between;
            align-items: center;
            padding: 15px 40px;
            background: rgba(255, 255, 255, 0.08);
            backdrop-filter: blur(14px);
            -webkit-backdrop-filter: blur(14px);
            border-bottom: 1px solid rgba(255, 255, 255, 0.1);
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            z-index: 1000;
            box-shadow: 0 4px 30px rgba(0, 0, 0, 0.1);
        }
        
        .navbar-brand {
            font-size: 1.6em;
            font-weight: 800;
            color: white;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 10px;
            letter-spacing: -0.5px;
        }
        
        .navbar-brand span {
            background: linear-gradient(135deg, #fff 0%, #a5b4fc 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
        }
        
        .navbar-links {
            display: flex;
            align-items: center;
            gap: 15px;
        }
        
        .nav-link {
            color: rgba(255, 255, 255, 0.85);
            text-decoration: none;
            font-weight: 500;
            font-size: 0.95em;
            padding: 10px 18px;
            border-radius: 12px;
            transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
        }
        
        .nav-link:hover {
            color: white;
            background: rgba(255, 255, 255, 0.15);
            transform: translateY(-1px);
        }
        
        .nav-link.active {
            background: rgba(255, 255, 255, 0.2);
            color: white;
            font-weight: 600;
        }
        
        .profile-btn {
            background: linear-gradient(135deg, #818cf8 0%, #6366f1 100%);
            color: white !important;
            box-shadow: 0 4px 15px rgba(99, 102, 241, 0.3);
            display: flex;
            align-items: center;
            gap: 8px;
        }
        
        .profile-btn:hover {
            box-shadow: 0 6px 20px rgba(99, 102, 241, 0.4);
            background: linear-gradient(135deg, #9333ea 0%, #6366f1 100%);
        }

        .main-content {
            margin-top: 100px;
        }
        
        .flash-messages {
            position: fixed;
            top: 20px;
            left: 50%;
            transform: translateX(-50%);
            z-index: 9999;
            min-width: 300px;
            max-width: 500px;
        }
        
        .flash-message {
            padding: 16px 24px;
            border-radius: 12px;
            color: white;
            font-weight: 500;
            box-shadow: 0 8px 24px rgba(0,0,0,0.2);
            animation: flashSlideIn 3s ease forwards;
            margin-bottom: 10px;
        }
        
        .flash-message.success {
            background: linear-gradient(135deg, #4CAF50 0%, #45a049 100%);
        }
        
        .flash-message.info {
            background: linear-gradient(135deg, #2196F3 0%, #1976D2 100%);
        }
        
        .flash-message.warning {
            background: linear-gradient(135deg, #FF9800 0%, #F57C00 100%);
        }
        
        .flash-message.error {
            background: linear-gradient(135deg, #f44336 0%, #d32f2f 100%);
        }
        
        @keyframes flashSlideIn {
            0% {
                opacity: 0;
                transform: translateY(-20px);
            }
            10% {
                opacity: 1;
                transform: translateY(0);
            }
            90% {
                opacity: 1;
                transform: translateY(0);
            }
            100% {
                opacity: 0;
                transform: translateY(-20px);
                visibility: hidden;
            }
        }
    </style>
    {% block styles %}{% endblock %}
</head>
<body>
    {% for type, messages in app.flashes %}
        <div class="flash-messages">
            {% for message in messages %}
                <div class="flash-message {{ type }}">
                    {{ message }}
                </div>
            {% endfor %}
        </div>
    {% endfor %}
    
    <nav class="navbar">
        <a href="{{ path('home') }}" class="navbar-brand">
            <span>PhotoShare</span>
        </a>
        <div class="navbar-links">
            <a href="{{ path('home') }}" class="nav-link {{ app.request.attributes.get('_route') == 'home' ? 'active' : '' }}">Gallery</a>
            {% if app.session.get('user_id') %}
                <a href="{{ path('profile') }}" class="nav-link profile-btn {{ app.request.attributes.get('_route') == 'profile' ? 'active' : '' }}">
                    👤 My Profile
                </a>
                <a href="{{ path('logout') }}" class="nav-link">Logout</a>
            {% else %}
                <a href="{{ path('login') }}" class="nav-link profile-btn">
                    🔑 Login
                </a>
            {% endif %}
        </div>
    </nav>
    
    <div class="main-content">
        <div class="container">
            <header>
                <h1>📸 PhotoShare</h1>
                <p>Discover amazing photography from our community</p>
            </header>
            
            {% block body %}{% endblock %}
        </div>
    </div>
</body>
</html>

